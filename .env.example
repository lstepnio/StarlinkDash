STARLINK_TARGET=192.168.100.1:9200
DB_PATH=/data/starlinkdash.db
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Router SNMP (optional)
ROUTER_TARGET=
ROUTER_COMMUNITY=
ROUTER_LAN_IFACE=eth0
ROUTER_WAN_IFACE=eth1
ROUTER_WAN2_IFACE=eth2
ROUTER_POLL_INTERVAL=30

# Speedtest Tracker (optional)
SPEEDTEST_URL=
SPEEDTEST_API_TOKEN=
SPEEDTEST_POLL_INTERVAL=300

# Uptime Kuma (optional)
UPTIME_KUMA_URL=
UPTIME_KUMA_API_KEY=
UPTIME_KUMA_POLL_INTERVAL=60

# Tautulli (optional)
TAUTULLI_URL=
TAUTULLI_API_KEY=
TAUTULLI_POLL_INTERVAL=30

# AI assistant (optional, read-only)
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=
AI_API_KEY=
AI_TIMEOUT_S=20
AI_TEMPERATURE=0.2
AI_MAX_OUTPUT_TOKENS=220
AI_MAX_PROMPT_CHARS=300
AI_CACHE_TTL_S=120
AI_RATE_LIMIT_REQUESTS=6
AI_RATE_LIMIT_WINDOW_S=300
AI_DAILY_REQUEST_LIMIT=100
AI_DAILY_TOKEN_BUDGET=50000

# Retention
RETENTION_STARLINK_DAYS=30
RETENTION_ROUTER_DAYS=30
RETENTION_SPEEDTEST_DAYS=365
